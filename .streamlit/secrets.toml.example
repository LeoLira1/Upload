# Copie este arquivo para .streamlit/secrets.toml e preencha com as
# credenciais do MESMO banco Turso usado pelo dashboard CAMDA.
#
# No Streamlit Community Cloud, cole estes valores em
# Settings → Secrets (não faça commit do secrets.toml real).

TURSO_DATABASE_URL = "libsql://SEU-BANCO.turso.io"
TURSO_AUTH_TOKEN   = "SEU_TOKEN_AQUI"
